---
import { getCollection } from 'astro:content';
import { collectionFor, metaFor, docHref, diagramHref, uiFor, type Lang } from '../lib/i18n.ts';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = uiFor(lang).home;

const docs = (await getCollection(collectionFor(lang)))
  .map((d) => ({ id: d.id, href: docHref(lang, d.id), ...metaFor(lang, d.id) }))
  .sort((a, b) => a.order - b.order);
---

<section class="hero reveal reveal-1">
  <span class="eyebrow">{t.eyebrow}</span>
  <h1>{t.h1}</h1>
  <p class="lede">{t.lede}</p>

  <ul class="phases">
    {
      t.phases.map((p) => (
        <li>
          <b>{p.letter}</b> {p.word}
          {p.gloss && (
            <>
              <span class="sep">·</span>
              {p.gloss}
            </>
          )}
        </li>
      ))
    }
  </ul>

  <ul class="threelines">
    {
      t.lines.map((l, i) => (
        <li class={`${l.key} reveal reveal-${i + 2}`}>
          <span class="tag">{l.tag}</span>
          <span class="desc">{l.desc}</span>
        </li>
      ))
    }
  </ul>
</section>

<p class="section-label">{t.docsLabel}</p>
<div class="doc-cards">
  {
    docs.map((d) => (
      <a class="doc-card" href={d.href}>
        <div class="row">
          <h3>{d.title}</h3>
          <span class="arrow">→</span>
        </div>
        <p>{d.blurb}</p>
      </a>
    ))
  }

  <a class="doc-card" href={diagramHref(lang)}>
    <div class="row">
      <h3>{t.diagramCtaTitle}</h3>
      <span class="arrow">→</span>
    </div>
    <p>{t.diagramCtaSub}</p>
  </a>
</div>

<p class="section-label">{t.cardsLabel}</p>
<div class="card-gallery">
  {
    t.cards.map((c) => (
      <a class="ref-card" href={c.src} aria-label={c.title}>
        <img src={c.src} alt={c.title} loading="lazy" width="1040" height="660" />
      </a>
    ))
  }
</div>

<div class="lightbox" id="lightbox" hidden>
  <button class="lightbox-close" id="lightboxClose" type="button" aria-label={t.closeLabel}>×</button>
  <img class="lightbox-img" id="lightboxImg" src="" alt="" />
</div>

<script is:inline>
  (() => {
    const gallery = document.querySelector('.card-gallery');
    const box = document.getElementById('lightbox');
    const img = document.getElementById('lightboxImg');
    const closeBtn = document.getElementById('lightboxClose');
    if (!gallery || !box || !img || !closeBtn) return;

    let lastFocus = null;
    const open = (src, alt) => {
      img.src = src;
      img.alt = alt || '';
      box.hidden = false;
      document.body.style.overflow = 'hidden';
      lastFocus = document.activeElement;
      closeBtn.focus();
    };
    const close = () => {
      box.hidden = true;
      img.removeAttribute('src');
      document.body.style.overflow = '';
      if (lastFocus && lastFocus.focus) lastFocus.focus();
    };

    gallery.addEventListener('click', (e) => {
      const card = e.target.closest('.ref-card');
      if (!card) return;
      e.preventDefault();
      const im = card.querySelector('img');
      open(card.getAttribute('href'), im ? im.alt : '');
    });
    closeBtn.addEventListener('click', close);
    box.addEventListener('click', (e) => { if (e.target === box) close(); });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !box.hidden) close();
    });
  })();
</script>
