---
import Base from '../layouts/Base.astro';
---

<Base title="404">
  <section class="hero reveal reveal-1">
    <span class="eyebrow">404</span>
    <h1>这一页不在台账上</h1>
    <p class="lede">
      你要找的页面不存在，或已被移动。回到框架首页，从索引重新进入。
    </p>
    <p style="margin-top:2rem"><a href="/">← 返回框架首页</a></p>
  </section>
</Base>
