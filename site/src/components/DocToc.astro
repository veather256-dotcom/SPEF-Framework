---
/**
 * DocToc — sticky table-of-contents sidebar for docs pages.
 * Accepts pre-parsed headings and renders a scroll-spy nav.
 */
export interface TocHeading {
  id: string;
  text: string;
  level: 2 | 3;
}

interface Props {
  headings: TocHeading[];
  /** Locale-aware label for the TOC header. */
  label?: string;
}

const { headings, label = '目次' } = Astro.props;

/** GitHub-style slug matching rehype-slug output. */
export function slugify(text: string): string {
  return text
    .toLowerCase()
    .replace(/[^\w\s\u4e00-\u9fff-]/g, '') // keep CJK, alphanum, whitespace, hyphen
    .trim()
    .replace(/\s+/g, '-')
    .replace(/-+/g, '-')
    .replace(/^-|-$/g, '');
}
---

{headings.length > 0 && (
  <nav class="doc-toc" aria-label={label}>
    <span class="toc-label">{label}</span>
    <ol>
      {headings.map((h) => (
        <li class={`toc-item toc-l${h.level}`}>
          <a href={`#${h.id}`} data-toc={h.id}>{h.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}

<script>
  (() => {
    const toc = document.querySelector('.doc-toc');
    if (!toc) return;

    const links = toc.querySelectorAll<HTMLAnchorElement>('a[data-toc]');
    if (links.length === 0) return;

    const headingIds = [...links].map((a) => a.dataset.toc!);
    const headingEls = headingIds
      .map((id) => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    if (headingEls.length === 0) return;

    const observer = new IntersectionObserver(
      (entries) => {
        // Find the first heading that's significantly visible or the last one
        // that's above the viewport.
        let activeId: string | null = null;

        // Check from top to bottom; the last heading whose top is at or above
        // the viewport midpoint (or the first visible one) gets the highlight.
        for (const entry of entries) {
          if (entry.isIntersecting && entry.intersectionRatio > 0) {
            activeId = entry.target.id;
            break; // first visible heading wins
          }
        }

        // Fallback: if no heading is visible, find the last one above the fold.
        if (!activeId) {
          const vh = window.innerHeight;
          for (const el of [...headingEls].reverse()) {
            const rect = el.getBoundingClientRect();
            if (rect.top < vh * 0.3) {
              activeId = el.id;
              break;
            }
          }
        }

        // Update active link.
        links.forEach((a) => {
          const isActive = a.dataset.toc === activeId;
          a.classList.toggle('toc-active', isActive);
        });
      },
      { rootMargin: '-10% 0px -70% 0px', threshold: 0 },
    );

    headingEls.forEach((el) => observer.observe(el));
  })();
</script>

<style>
  .doc-toc {
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 7rem);
    overflow-y: auto;
    padding: 0;
    font-size: 0.88rem;
  }
  .toc-label {
    display: block;
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.8rem;
  }
  .doc-toc ol {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .toc-item a {
    display: block;
    padding: 0.25rem 0.55rem;
    border-radius: 6px;
    color: var(--muted);
    text-decoration: none;
    line-height: 1.5;
    border-left: 2px solid transparent;
    transition: color 0.15s ease, background 0.15s ease, border-color 0.15s ease;
  }
  .toc-item a:hover {
    color: var(--ink-soft);
    background: color-mix(in srgb, var(--surface-2) 60%, transparent);
  }
  .toc-item a.toc-active {
    color: var(--ink);
    border-left-color: var(--accent);
    background: color-mix(in srgb, var(--accent-soft) 50%, transparent);
  }
  .toc-l3 a { padding-left: 1.8rem; font-size: 0.94em; }

  /* ---- mobile: collapse to overlay ---- */
  @media (max-width: 1023px) {
    .doc-toc {
      display: none;
    }
  }
</style>