---
import Base from '../layouts/Base.astro';
import { uiFor, homeHref } from '../lib/i18n.ts';
const t = uiFor('zh').notFound;
---

<Base lang="zh" title="404">
  <section class="hero reveal reveal-1">
    <span class="eyebrow">{t.eyebrow}</span>
    <h1>{t.h1}</h1>
    <p class="lede">{t.lede}</p>
    <p style="margin-top:2rem"><a href={homeHref('zh')}>{t.back}</a></p>
  </section>
</Base>
