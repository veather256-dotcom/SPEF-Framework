---
import 'katex/dist/katex.min.css';
import '../styles/global.css';
import { uiFor, otherLang, prefix, type Lang } from '../lib/i18n.ts';

interface Props {
  /** Active locale. Defaults to the root locale (zh). */
  lang?: Lang;
  title?: string;
  description?: string;
  /** When true, main fills the viewport with no padding (used by the diagram page). */
  bleed?: boolean;
}

const { lang = 'zh', title, description, bleed = false } = Astro.props;
const t = uiFor(lang);
const desc = description ?? t.siteDescription;

const pageTitle = title ? `${title} · SPEF` : 'SPEF';
const home = prefix(lang) + '/';
const diagram = prefix(lang) + '/diagram';

const path = Astro.url.pathname;
const isHome = path === home || path === prefix(lang) || path === prefix(lang) + '/';
const isDiagram = path.startsWith(diagram);

// Language switcher target: the equivalent page in the other locale.
const other = otherLang(lang);
const rest = lang === 'en' ? path.replace(/^\/en/, '') || '/' : path;
const switchHref = (other === 'en' ? '/en' + rest : rest).replace(/\/{2,}/g, '/');
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={desc} />
    <meta name="theme-color" content="#fbfaf8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#070d1a" media="(prefers-color-scheme: dark)" />
    <title>{pageTitle}</title>
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('spef-theme');
          if (saved === 'light' || saved === 'dark') {
            document.documentElement.setAttribute('data-theme', saved);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    {!bleed && <div class="read-progress" id="readProgress"></div>}

    <header class="site-header">
      <div class="bar">
        <a href={home} class="brand"><span class="dot" aria-hidden="true"></span>SPEF</a>
        <nav>
          <a href={home} class={isHome ? 'active' : ''}>{t.nav.framework}</a>
          <a href={diagram} class={isDiagram ? 'active' : ''}>{t.nav.diagram}</a>
          <a class="lang-switch" href={switchHref} hreflang={other} rel="alternate">{t.nav.switchLang}</a>
          <button
            type="button"
            class="theme-toggle"
            id="themeToggle"
            aria-label={t.nav.toggleTheme}
            title={t.nav.toggleTheme}>
            <svg class="moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
            </svg>
            <svg class="sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <main class={bleed ? 'bleed' : ''}>
      <slot />
    </main>

    {
      !bleed && (
        <footer class="site-footer">
          <p>{t.footer.line}</p>
          <p class="fine">{t.footer.fine}</p>
        </footer>
      )
    }

    <script is:inline>
      (() => {
        const btn = document.getElementById('themeToggle');
        if (btn) {
          btn.addEventListener('click', () => {
            const root = document.documentElement;
            const current =
              root.getAttribute('data-theme') ||
              (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            const next = current === 'dark' ? 'light' : 'dark';
            root.setAttribute('data-theme', next);
            try { localStorage.setItem('spef-theme', next); } catch (e) {}
          });
        }

        const bar = document.getElementById('readProgress');
        if (bar) {
          const update = () => {
            const h = document.documentElement;
            const max = h.scrollHeight - h.clientHeight;
            const pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
            bar.style.width = pct + '%';
          };
          update();
          window.addEventListener('scroll', update, { passive: true });
          window.addEventListener('resize', update, { passive: true });
        }
      })();
    </script>
  </body>
</html>
